# Copy to /etc/duo-gateway/gateway.env (chmod 600, owner duogw).
# In the Terraform deploy these values are injected from instance metadata,
# so you normally never edit this by hand on the box.

# Long random string — signs session cookies. Generate: openssl rand -hex 32
GATEWAY_SECRET_KEY=CHANGE_ME

# From the Duo Admin Panel -> Applications -> "Web SDK" (Duo Universal Prompt)
DUO_CLIENT_ID=DICHANGEME
DUO_CLIENT_SECRET=CHANGE_ME
DUO_API_HOST=api-XXXXXXXX.duosecurity.com

# Public hostname (must match the cert / Duo redirect URI)
SERVER_NAME=lab.radiobelcher.com

# Where EVE-NG's Apache listens internally
EVE_UPSTREAM=http://127.0.0.1:80

# Gateway session lifetime in seconds (default 8h)
SESSION_TTL=28800
