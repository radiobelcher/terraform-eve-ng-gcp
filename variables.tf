variable "project_id" {
  description = "GCP Project ID"
  type        = string
}

variable "region" {
  description = "GCP Region"
  type        = string
  default     = "us-central1"
}

variable "zone" {
  description = "GCP Zone"
  type        = string
  default     = "us-central1-a"
}

variable "google_credentials_b64" {
  description = "Base64-encoded GCP credentials JSON"
  type        = string
}

variable "custom_image_name" {}
